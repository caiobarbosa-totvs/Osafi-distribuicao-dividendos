        <di:waypoint x="1085" y="580"/>
        <bpmndi:BPMNLabel><dc:Bounds x="1091" y="375" width="18" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- IntRMTotvs → ProgPag (L5→L4) -->
      <bpmndi:BPMNEdge id="Flow_RMtoProgPag_di" bpmnElement="Flow_RMtoProgPag">
