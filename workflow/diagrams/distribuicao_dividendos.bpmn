      </bpmndi:BPMNEdge>

      <!-- IntRMRegular → ProgPagRegular (L5→L4) -->
      <bpmndi:BPMNEdge id="Flow_IntRMRegToProgReg_di" bpmnElement="Flow_IntRMRegToProgReg">
