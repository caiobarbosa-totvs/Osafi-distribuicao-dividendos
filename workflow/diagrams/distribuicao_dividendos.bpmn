        <di:waypoint x="505" y="515"/>
        <bpmndi:BPMNLabel><dc:Bounds x="511" y="496" width="45" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- GatDecisao → SolAta (sobe L3→L1, Distribuição Regular) -->
      <bpmndi:BPMNEdge id="Flow_Regular_di" bpmnElement="Flow_Regular">
