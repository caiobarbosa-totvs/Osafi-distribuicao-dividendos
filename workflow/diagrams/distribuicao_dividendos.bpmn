        <di:waypoint x="1035" y="160"/>
      </bpmndi:BPMNEdge>

      <!-- GatAta → SolAta (loop Não) -->
      <bpmndi:BPMNEdge id="Flow_AtaLoop_di" bpmnElement="Flow_AtaLoop">
