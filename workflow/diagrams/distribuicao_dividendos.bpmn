      <!-- ProgPag → ValPag -->
      <bpmndi:BPMNEdge id="Flow_07_di" bpmnElement="Flow_07">
        <di:waypoint x="790" y="620"/>
        <di:waypoint x="845" y="620"/>
      </bpmndi:BPMNEdge>

      <!-- ValPag → ConcFin (desce row) -->
      <bpmndi:BPMNEdge id="Flow_08_di" bpmnElement="Flow_08">
        <di:waypoint x="905" y="660"/>
        <di:waypoint x="905" y="690"/>
      </bpmndi:BPMNEdge>

      <!-- ConcFin → AnexaComp -->
      <bpmndi:BPMNEdge id="Flow_09_di" bpmnElement="Flow_09">
        <di:waypoint x="965" y="730"/>
        <di:waypoint x="1015" y="730"/>
      </bpmndi:BPMNEdge>

      <!-- AnexaComp → IntContabil (L4→L5) -->
      <bpmndi:BPMNEdge id="Flow_10_di" bpmnElement="Flow_10">
        <di:waypoint x="1135" y="730"/>
        <di:waypoint x="1255" y="730"/>
        <di:waypoint x="1255" y="830"/>
      </bpmndi:BPMNEdge>

      <!-- IntContabil → ConcContabil (L5→L4) -->
      <bpmndi:BPMNEdge id="Flow_ContabilToConcContabil_di" bpmnElement="Flow_ContabilToConcContabil">
