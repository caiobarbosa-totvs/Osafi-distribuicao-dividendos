        <bpmndi:BPMNLabel><dc:Bounds x="890" y="82" width="21" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- GatAta → Provisoes (Sim, L1→L4) -->
      <bpmndi:BPMNEdge id="Flow_AtaSim_di" bpmnElement="Flow_AtaSim">
